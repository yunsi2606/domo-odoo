<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Template List View -->
    <record id="hr_appraisal_template_view_list" model="ir.ui.view">
        <field name="name">hr.appraisal.template.list</field>
        <field name="model">hr.appraisal.template</field>
        <field name="arch" type="xml">
            <list string="Appraisal Templates">
                <field name="name"/>
                <field name="description"/>
                <field name="employee_self_assessment"/>
                <field name="skills_assessment"/>
                <field name="goals_tracking"/>
                <field name="appraisal_count"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    
    <!-- Template Form View -->
    <record id="hr_appraisal_template_view_form" model="ir.ui.view">
        <field name="name">hr.appraisal.template.form</field>
        <field name="model">hr.appraisal.template</field>
        <field name="arch" type="xml">
            <form string="Appraisal Template">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_appraisals" type="object"
                                class="oe_stat_button" icon="fa-clipboard">
                            <div class="o_stat_info">
                                <field name="appraisal_count" class="o_stat_value"/>
                                <span class="o_stat_text">Appraisals</span>
                            </div>
                        </button>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Template Name"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Settings">
                            <field name="employee_self_assessment"/>
                            <field name="skills_assessment"/>
                            <field name="goals_tracking"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    
                    <notebook>
                        <page string="Skills to Evaluate" name="skills">
                            <field name="skill_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="weight"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                        <page string="Default Goals" name="goals">
                            <field name="goal_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="weight"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Template Search View -->
    <record id="hr_appraisal_template_view_search" model="ir.ui.view">
        <field name="name">hr.appraisal.template.search</field>
        <field name="model">hr.appraisal.template</field>
        <field name="arch" type="xml">
            <search string="Search Templates">
                <field name="name"/>
                <filter name="filter_active" string="Active"
                        domain="[('active', '=', True)]"/>
                <filter name="filter_archived" string="Archived"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    
    <!-- Template Actions -->
    <record id="action_hr_appraisal_template" model="ir.actions.act_window">
        <field name="name">Appraisal Templates</field>
        <field name="res_model">hr.appraisal.template</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_appraisal_template_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first appraisal template!
            </p>
            <p>
                Templates allow you to define standard skills and goals
                to be used in appraisals.
            </p>
        </field>
    </record>
    
</odoo>
