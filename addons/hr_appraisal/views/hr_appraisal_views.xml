<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Appraisal List View -->
    <record id="hr_appraisal_view_list" model="ir.ui.view">
        <field name="name">hr.appraisal.list</field>
        <field name="model">hr.appraisal</field>
        <field name="arch" type="xml">
            <list string="Appraisals"
                  decoration-danger="state == 'cancel'"
                  decoration-success="state == 'done'"
                  decoration-info="state in ('employee_feedback', 'manager_feedback')"
                  multi_edit="1">
                <field name="employee_id" widget="many2one_avatar_employee"/>
                <field name="department_id"/>
                <field name="manager_id" widget="many2one_avatar_employee"/>
                <field name="date_close"/>
                <field name="final_rating" widget="priority"/>
                <field name="goals_completion" widget="progressbar"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('new', 'pending')"
                       decoration-warning="state in ('employee_feedback', 'manager_feedback')"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancel'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    
    <!-- Appraisal Form View -->
    <record id="hr_appraisal_view_form" model="ir.ui.view">
        <field name="name">hr.appraisal.form</field>
        <field name="model">hr.appraisal</field>
        <field name="arch" type="xml">
            <form string="Appraisal">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary" invisible="state != 'new'"/>
                    <button name="action_start_employee_feedback" type="object" 
                            string="Start Employee Feedback"
                            class="btn-primary" invisible="state != 'pending'"/>
                    <button name="action_submit_employee_feedback" type="object" 
                            string="Submit Self-Assessment"
                            class="btn-primary" 
                            invisible="state != 'employee_feedback' or not is_employee"/>
                    <button name="action_submit_manager_feedback" type="object" 
                            string="Submit Assessment"
                            class="btn-primary" 
                            invisible="state != 'manager_feedback' or not is_manager"/>
                    <button name="action_schedule_meeting" type="object" 
                            string="Schedule Meeting"
                            class="btn-secondary"
                            invisible="state in ('new', 'done', 'cancel')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('done', 'cancel')"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state not in ('cancel',)"
                            groups="hr_appraisal.group_appraisal_manager"/>
                    <field name="state" widget="statusbar" 
                           statusbar_visible="new,pending,employee_feedback,manager_feedback,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_goals" type="object"
                                class="oe_stat_button" icon="fa-bullseye">
                            <div class="o_stat_info">
                                <field name="goal_count" class="o_stat_value"/>
                                <span class="o_stat_text">Goals</span>
                            </div>
                        </button>
                        <button name="action_view_skills" type="object"
                                class="oe_stat_button" icon="fa-star">
                            <div class="o_stat_info">
                                <field name="skill_count" class="o_stat_value"/>
                                <span class="o_stat_text">Skills</span>
                            </div>
                        </button>
                    </div>
                    
                    <widget name="web_ribbon" title="Done" bg_color="text-bg-success"
                            invisible="state != 'done'"/>
                    <widget name="web_ribbon" title="Cancelled" bg_color="text-bg-danger"
                            invisible="state != 'cancel'"/>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Employee Information">
                            <field name="employee_id" widget="many2one_avatar_employee"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                            <field name="manager_id" widget="many2one_avatar_employee"/>
                        </group>
                        <group string="Appraisal Period">
                            <field name="appraisal_period_start"/>
                            <field name="appraisal_period_end"/>
                            <field name="date_close"/>
                            <field name="template_id"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <!-- Employee Self-Assessment Tab -->
                        <page string="Self-Assessment" name="employee_assessment">
                            <group>
                                <group string="Self-Rating">
                                    <field name="employee_rating" widget="priority"/>
                                </group>
                                <group>
                                    <field name="employee_feedback_date" readonly="1"/>
                                </group>
                            </group>
                            <group string="Self-Assessment">
                                <field name="employee_self_assessment" nolabel="1" 
                                       placeholder="Describe your overall performance during this period..."/>
                            </group>
                            <group string="Key Achievements">
                                <field name="employee_achievements" nolabel="1"
                                       placeholder="List your key accomplishments and successes..."/>
                            </group>
                            <group string="Challenges Faced">
                                <field name="employee_challenges" nolabel="1"
                                       placeholder="Describe any challenges or difficulties you faced..."/>
                            </group>
                            <group string="Development Goals">
                                <field name="employee_development" nolabel="1"
                                       placeholder="Areas where you want to develop and grow..."/>
                            </group>
                        </page>
                        
                        <!-- Manager Assessment Tab -->
                        <page string="Manager Assessment" name="manager_assessment">
                            <group>
                                <group string="Manager Rating">
                                    <field name="manager_rating" widget="priority"/>
                                    <field name="final_rating" widget="priority"/>
                                </group>
                                <group>
                                    <field name="manager_feedback_date" readonly="1"/>
                                    <field name="rating_score"/>
                                </group>
                            </group>
                            <group string="Manager Assessment">
                                <field name="manager_assessment" nolabel="1"
                                       placeholder="Overall assessment of the employee's performance..."/>
                            </group>
                            <group string="Employee Strengths">
                                <field name="manager_strengths" nolabel="1"
                                       placeholder="Key strengths demonstrated by the employee..."/>
                            </group>
                            <group string="Areas for Improvement">
                                <field name="manager_improvements" nolabel="1"
                                       placeholder="Areas where the employee needs to improve..."/>
                            </group>
                            <group string="Recommendations">
                                <field name="manager_recommendations" nolabel="1"
                                       placeholder="Recommendations for career development..."/>
                            </group>
                        </page>
                        
                        <!-- Goals Tab -->
                        <page string="Goals" name="goals">
                            <group>
                                <group>
                                    <field name="goals_completion" widget="progressbar"/>
                                </group>
                            </group>
                            <field name="goal_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="priority"/>
                                    <field name="deadline"/>
                                    <field name="progress" widget="progressbar"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        
                        <!-- Skills Tab -->
                        <page string="Skills Assessment" name="skills">
                            <group>
                                <group>
                                    <field name="skills_average"/>
                                </group>
                            </group>
                            <field name="skill_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="employee_rating"/>
                                    <field name="manager_rating"/>
                                    <field name="rating"/>
                                    <field name="weight"/>
                                </list>
                            </field>
                        </page>
                        
                        <!-- Meeting Notes Tab -->
                        <page string="Notes" name="notes">
                            <field name="note_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="note_type"/>
                                    <field name="author_id"/>
                                    <field name="visibility"/>
                                    <field name="action_status" invisible="note_type != 'action_item'"/>
                                </list>
                            </field>
                            <button name="action_add_note" type="object" 
                                    string="Add Note" class="btn-secondary mt-3"/>
                        </page>
                    </notebook>
                    
                    <field name="is_employee" invisible="1"/>
                    <field name="is_manager" invisible="1"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <!-- Appraisal Calendar View -->
    <record id="hr_appraisal_view_calendar" model="ir.ui.view">
        <field name="name">hr.appraisal.calendar</field>
        <field name="model">hr.appraisal</field>
        <field name="arch" type="xml">
            <calendar string="Appraisals"
                      date_start="date_close"
                      color="state"
                      mode="month"
                      quick_create="0">
                <field name="employee_id" avatar_field="avatar_128"/>
                <field name="state"/>
                <field name="final_rating"/>
            </calendar>
        </field>
    </record>
    
    <!-- Appraisal Kanban View -->
    <record id="hr_appraisal_view_kanban" model="ir.ui.view">
        <field name="name">hr.appraisal.kanban</field>
        <field name="model">hr.appraisal</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state" sample="1">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="date_close"/>
                <field name="state"/>
                <field name="final_rating"/>
                <field name="goals_completion"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top mb-2">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="employee_id" widget="many2one_avatar_employee"/>
                                </strong>
                            </div>
                        </div>
                        <div class="mb-2">
                            <field name="department_id"/>
                        </div>
                        <div class="text-muted">
                            <i class="fa fa-calendar me-1"/>
                            Deadline: <field name="date_close"/>
                        </div>
                        <div class="mt-2">
                            <field name="final_rating" widget="priority"/>
                        </div>
                        <div class="mt-2">
                            <span class="badge bg-primary">
                                <field name="goals_completion"/>% Goals
                            </span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Appraisal Search View -->
    <record id="hr_appraisal_view_search" model="ir.ui.view">
        <field name="name">hr.appraisal.search</field>
        <field name="model">hr.appraisal</field>
        <field name="arch" type="xml">
            <search string="Search Appraisals">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="manager_id"/>
                <field name="template_id"/>
                <separator/>
                <filter name="filter_my_appraisals" string="My Appraisals"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <filter name="filter_my_team" string="My Team"
                        domain="[('manager_id.user_id', '=', uid)]"/>
                <separator/>
                <filter name="filter_new" string="To Confirm"
                        domain="[('state', '=', 'new')]"/>
                <filter name="filter_pending" string="Confirmed"
                        domain="[('state', '=', 'pending')]"/>
                <filter name="filter_employee_feedback" string="Employee Feedback"
                        domain="[('state', '=', 'employee_feedback')]"/>
                <filter name="filter_manager_feedback" string="Manager Feedback"
                        domain="[('state', '=', 'manager_feedback')]"/>
                <filter name="filter_done" string="Done"
                        domain="[('state', '=', 'done')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter name="group_department" string="Department"
                            context="{'group_by': 'department_id'}"/>
                    <filter name="group_manager" string="Manager"
                            context="{'group_by': 'manager_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_rating" string="Final Rating"
                            context="{'group_by': 'final_rating'}"/>
                    <filter name="group_deadline" string="Deadline"
                            context="{'group_by': 'date_close:month'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Appraisal Actions -->
    <record id="action_hr_appraisal" model="ir.actions.act_window">
        <field name="name">Appraisals</field>
        <field name="res_model">hr.appraisal</field>
        <field name="view_mode">list,kanban,form,calendar</field>
        <field name="search_view_id" ref="hr_appraisal_view_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first appraisal!
            </p>
            <p>
                Manage employee performance evaluations with schedules,
                goals tracking, and skills assessment.
            </p>
        </field>
    </record>
    
    <record id="action_hr_appraisal_my" model="ir.actions.act_window">
        <field name="name">My Appraisals</field>
        <field name="res_model">hr.appraisal</field>
        <field name="view_mode">list,kanban,form,calendar</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_filter_my_appraisals': 1}</field>
    </record>
    
    <record id="action_hr_appraisal_team" model="ir.actions.act_window">
        <field name="name">My Team Appraisals</field>
        <field name="res_model">hr.appraisal</field>
        <field name="view_mode">list,kanban,form,calendar</field>
        <field name="domain">[('manager_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_filter_my_team': 1}</field>
    </record>
    
    <record id="action_hr_appraisal_pending" model="ir.actions.act_window">
        <field name="name">Pending Appraisals</field>
        <field name="res_model">hr.appraisal</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('state', 'not in', ['done', 'cancel'])]</field>
    </record>
    
</odoo>
