<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Skill List View -->
    <record id="hr_appraisal_skill_view_list" model="ir.ui.view">
        <field name="name">hr.appraisal.skill.list</field>
        <field name="model">hr.appraisal.skill</field>
        <field name="arch" type="xml">
            <list string="Skills Assessment" editable="bottom">
                <field name="name"/>
                <field name="category"/>
                <field name="employee_rating"/>
                <field name="manager_rating"/>
                <field name="rating"/>
                <field name="weight"/>
                <field name="improvement"/>
                <field name="appraisal_id" column_invisible="1"/>
            </list>
        </field>
    </record>
    
    <!-- Skill Form View -->
    <record id="hr_appraisal_skill_view_form" model="ir.ui.view">
        <field name="name">hr.appraisal.skill.form</field>
        <field name="model">hr.appraisal.skill</field>
        <field name="arch" type="xml">
            <form string="Skill Assessment">
                <sheet>
                    <group>
                        <group string="Skill Information">
                            <field name="name"/>
                            <field name="category"/>
                            <field name="weight"/>
                        </group>
                        <group string="Ratings">
                            <field name="employee_rating"/>
                            <field name="manager_rating"/>
                            <field name="rating"/>
                            <field name="previous_rating"/>
                            <field name="improvement"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <group>
                        <group string="Employee Comment">
                            <field name="employee_comment" nolabel="1"/>
                        </group>
                        <group string="Manager Comment">
                            <field name="manager_comment" nolabel="1"/>
                        </group>
                    </group>
                    <field name="appraisal_id" invisible="1"/>
                    <field name="employee_id" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Skill Search View -->
    <record id="hr_appraisal_skill_view_search" model="ir.ui.view">
        <field name="name">hr.appraisal.skill.search</field>
        <field name="model">hr.appraisal.skill</field>
        <field name="arch" type="xml">
            <search string="Search Skills">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="category"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter name="group_category" string="Category"
                            context="{'group_by': 'category'}"/>
                    <filter name="group_rating" string="Rating"
                            context="{'group_by': 'rating'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Skill Category Views -->
    <record id="hr_appraisal_skill_category_view_list" model="ir.ui.view">
        <field name="name">hr.appraisal.skill.category.list</field>
        <field name="model">hr.appraisal.skill.category</field>
        <field name="arch" type="xml">
            <list string="Skill Categories" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>
    
    <!-- Skill Actions -->
    <record id="action_hr_appraisal_skill" model="ir.actions.act_window">
        <field name="name">Skills Assessment</field>
        <field name="res_model">hr.appraisal.skill</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_appraisal_skill_view_search"/>
    </record>
    
    <record id="action_hr_appraisal_skill_category" model="ir.actions.act_window">
        <field name="name">Skill Categories</field>
        <field name="res_model">hr.appraisal.skill.category</field>
        <field name="view_mode">list</field>
    </record>
    
</odoo>
