<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Cron: Send Appraisal Reminders -->
    <record id="ir_cron_appraisal_reminder" model="ir.cron">
        <field name="name">Appraisal: Send Deadline Reminders</field>
        <field name="model_id" ref="model_hr_appraisal"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_reminders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
    
    <!-- Cron: Create Periodic Appraisals -->
    <record id="ir_cron_appraisal_create" model="ir.cron">
        <field name="name">Appraisal: Create Periodic Appraisals</field>
        <field name="model_id" ref="model_hr_appraisal"/>
        <field name="state">code</field>
        <field name="code">model._cron_create_periodic_appraisals()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">weeks</field>
        <field name="active">False</field>
    </record>
    
</odoo>
