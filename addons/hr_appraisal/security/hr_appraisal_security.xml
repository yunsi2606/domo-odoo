<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Appraisal Module Category -->
    <record id="module_category_hr_appraisal" model="ir.module.category">
        <field name="name">Appraisal</field>
        <field name="description">Manage employee appraisals and performance evaluations</field>
        <field name="sequence">10</field>
    </record>
    
    <!-- User Group -->
    <record id="group_appraisal_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_hr_appraisal"/>
        <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="comment">Access to own appraisals and basic appraisal features</field>
    </record>
    
    <!-- Manager Group - HR Managers automatically get this group -->
    <record id="group_appraisal_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_hr_appraisal"/>
        <field name="implied_ids" eval="[(4, ref('group_appraisal_user'))]"/>
        <field name="comment">Full access to all appraisal features</field>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
    
    <!-- Make HR Manager imply Appraisal Manager -->
    <record id="hr.group_hr_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_appraisal_manager'))]"/>
    </record>
    
    <!-- Record Rules -->
    
    <!-- Appraisal - Users can see their own appraisals -->
    <record id="appraisal_rule_user" model="ir.rule">
        <field name="name">Appraisal: User - Own</field>
        <field name="model_id" ref="model_hr_appraisal"/>
        <field name="domain_force">[
            '|', '|',
            ('employee_id.user_id', '=', user.id),
            ('manager_id.user_id', '=', user.id),
            ('employee_id.parent_id.user_id', '=', user.id)
        ]</field>
        <field name="groups" eval="[(4, ref('group_appraisal_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    
    <!-- Appraisal - Managers can see all -->
    <record id="appraisal_rule_manager" model="ir.rule">
        <field name="name">Appraisal: Manager - All</field>
        <field name="model_id" ref="model_hr_appraisal"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_appraisal_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    
    <!-- Goals - Managers can see all -->
    <record id="goal_rule_manager" model="ir.rule">
        <field name="name">Appraisal Goal: Manager - All</field>
        <field name="model_id" ref="model_hr_appraisal_goal"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_appraisal_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    
    <!-- Goals - Users can see goals for their appraisals -->
    <record id="goal_rule_user" model="ir.rule">
        <field name="name">Appraisal Goal: User - Own Appraisals</field>
        <field name="model_id" ref="model_hr_appraisal_goal"/>
        <field name="domain_force">[
            '|',
            ('appraisal_id.employee_id.user_id', '=', user.id),
            ('appraisal_id.manager_id.user_id', '=', user.id)
        ]</field>
        <field name="groups" eval="[(4, ref('group_appraisal_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    
    <!-- Skills - Managers can see all -->
    <record id="skill_rule_manager" model="ir.rule">
        <field name="name">Appraisal Skill: Manager - All</field>
        <field name="model_id" ref="model_hr_appraisal_skill"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_appraisal_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    
    <!-- Skills - Users can see skills for their appraisals -->
    <record id="skill_rule_user" model="ir.rule">
        <field name="name">Appraisal Skill: User - Own Appraisals</field>
        <field name="model_id" ref="model_hr_appraisal_skill"/>
        <field name="domain_force">[
            '|',
            ('appraisal_id.employee_id.user_id', '=', user.id),
            ('appraisal_id.manager_id.user_id', '=', user.id)
        ]</field>
        <field name="groups" eval="[(4, ref('group_appraisal_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    
    <!-- Notes - Managers can see all -->
    <record id="note_rule_manager" model="ir.rule">
        <field name="name">Appraisal Note: Manager - All</field>
        <field name="model_id" ref="model_hr_appraisal_note"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_appraisal_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    
    <!-- Notes - Users can see shared notes or their own -->
    <record id="note_rule_user" model="ir.rule">
        <field name="name">Appraisal Note: User - Own/Shared</field>
        <field name="model_id" ref="model_hr_appraisal_note"/>
        <field name="domain_force">[
            '|',
            ('visibility', '=', 'shared'),
            ('author_id', '=', user.id)
        ]</field>
        <field name="groups" eval="[(4, ref('group_appraisal_user'))]"/>
    </record>
    
    <!-- Company Rule -->
    <record id="appraisal_rule_company" model="ir.rule">
        <field name="name">Appraisal: Multi-Company</field>
        <field name="model_id" ref="model_hr_appraisal"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
</odoo>
