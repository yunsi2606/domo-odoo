<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_sales_record_view_list" model="ir.ui.view">
        <field name="name">hr.sales.record.list</field>
        <field name="model">hr.sales.record</field>
        <field name="arch" type="xml">
            <list string="Sales Records">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="shift"/>
                <field name="sales_amount" widget="monetary" sum="Total"/>
                <field name="products_sold" sum="Total"/>
                <field name="hot_bonus_preview" widget="monetary" string="Hot Bonus"/>
                <field name="livestream_bonus_preview" widget="monetary" string="Live Bonus"/>
                <field name="source" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="hr_sales_record_view_form" model="ir.ui.view">
        <field name="name">hr.sales.record.form</field>
        <field name="model">hr.sales.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="employee_id" options="{'no_create':True}"/>
                        <field name="date"/>
                        <field name="shift"/>
                        <field name="sales_amount"/>
                        <field name="products_sold"/>
                        <field name="source"/>
                        <field name="note"/>
                    </group>
                    <group string="Bonus Preview">
                        <field name="hot_bonus_preview" readonly="1"/>
                        <field name="livestream_bonus_preview" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_sales_record_view_search" model="ir.ui.view">
        <field name="name">hr.sales.record.search</field>
        <field name="model">hr.sales.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="date"/>
                <filter string="Excel Import" name="excel" domain="[('source','=','excel')]"/>
                <filter string="This Month" name="this_month"
                        domain="[('is_this_month', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_by_employee" context="{'group_by':'employee_id'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by':'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sales_records" model="ir.actions.act_window">
        <field name="name">Sales Records</field>
        <field name="res_model">hr.sales.record</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_sales_record_view_search"/>
    </record>

    <record id="action_sales_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Sales from Excel</field>
        <field name="res_model">hr.sales.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
