<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_offboarding_user" model="res.groups">
            <field name="name">Offboarding User (Branch Manager)</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_offboarding_manager" model="res.groups">
            <field name="name">Offboarding Manager (Director / HR)</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('group_offboarding_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
