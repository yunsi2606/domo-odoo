<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Asset Category -->
    <record id="hr_asset_category_view_list" model="ir.ui.view">
        <field name="name">hr.asset.category.list</field>
        <field name="model">hr.asset.category</field>
        <field name="arch" type="xml">
            <list string="Asset Categories" editable="bottom">
                <field name="name"/>
                <field name="asset_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <!-- Asset Form -->
    <record id="hr_asset_view_form" model="ir.ui.view">
        <field name="name">hr.asset.form</field>
        <field name="model">hr.asset</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <header>
                    <field name="state" widget="statusbar"
                           options="{'clickable': '1'}"
                           statusbar_visible="available,assigned,maintenance,retired"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category_id" options="{'no_create_edit':True}"/>
                            <field name="value"/>
                        </group>
                        <group>
                            <field name="assigned_employee_id" options="{'no_create':True}"/>
                            <field name="assignment_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Optional descriptions..."/>
                    <separator string="Assignment History"/>
                    <field name="assignment_ids" readonly="1">
                        <list>
                            <field name="employee_id"/>
                            <field name="date_assign"/>
                            <field name="date_return"/>
                            <field name="return_condition" widget="badge"
                                   decoration-success="return_condition == 'good'"
                                   decoration-warning="return_condition == 'damaged'"
                                   decoration-danger="return_condition == 'lost'"/>
                            <field name="note"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Asset List -->
    <record id="hr_asset_view_list" model="ir.ui.view">
        <field name="name">hr.asset.list</field>
        <field name="model">hr.asset</field>
        <field name="arch" type="xml">
            <list string="Assets"
                  decoration-warning="state == 'assigned'"
                  decoration-muted="state in ('maintenance','retired')">
                <field name="code"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="value" widget="monetary"/>
                <field name="assigned_employee_id"/>
                <field name="assignment_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-info="state == 'assigned'"
                       decoration-warning="state == 'maintenance'"
                       decoration-muted="state == 'retired'"/>
            </list>
        </field>
    </record>

    <!-- Asset Search -->
    <record id="hr_asset_view_search" model="ir.ui.view">
        <field name="name">hr.asset.search</field>
        <field name="model">hr.asset</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="assigned_employee_id"/>
                <filter string="Available" name="available" domain="[('state','=','available')]"/>
                <filter string="Assigned" name="assigned" domain="[('state','=','assigned')]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by':'category_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by':'state'}"/>
                    <filter string="Employee" name="group_employee" context="{'group_by':'assigned_employee_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_hr_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">hr.asset</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_asset_view_search"/>
    </record>

    <record id="action_hr_asset_category" model="ir.actions.act_window">
        <field name="name">Asset Categories</field>
        <field name="res_model">hr.asset.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Extend Employee form -->
    <record id="hr_employee_asset_form" model="ir.ui.view">
        <field name="name">hr.employee.asset.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" icon="fa-laptop"
                        name="action_view_assets" type="object">
                    <field name="assigned_asset_count" widget="statinfo" string="Assets"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
