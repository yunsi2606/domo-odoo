<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Commission Record List -->
    <record id="view_commission_record_list" model="ir.ui.view">
        <field name="name">hr.commission.record.list</field>
        <field name="model">hr.commission.record</field>
        <field name="arch" type="xml">
            <list string="Commission Records" decoration-info="state == 'draft'"
                  decoration-success="state == 'confirmed'" decoration-muted="state == 'locked'">
                <field name="employee_id"/>
                <field name="month"/>
                <field name="year"/>
                <field name="total_orders"/>
                <field name="total_revenue"/>
                <field name="commission_rate"/>
                <field name="commission_amount"/>
                <field name="state" widget="badge"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
            </list>
        </field>
    </record>
    
    <!-- Commission Record Form -->
    <record id="view_commission_record_form" model="ir.ui.view">
        <field name="name">hr.commission.record.form</field>
        <field name="model">hr.commission.record</field>
        <field name="arch" type="xml">
            <form string="Commission Record">
                <header>
                    <button name="action_confirm" type="object" string="Confirm" 
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_lock" type="object" string="Lock"
                            invisible="state != 'confirmed'"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state != 'confirmed'"/>
                    <button name="action_recalculate" type="object" string="Recalculate"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,locked"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="display_name" readonly="1"/></h1></div>
                    <group>
                        <group string="Employee">
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/>
                        </group>
                        <group string="Period">
                            <field name="month" readonly="state != 'draft'"/>
                            <field name="year" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group>
                        <group string="Totals">
                            <field name="total_orders"/>
                            <field name="total_revenue"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Commission">
                            <field name="rule_id"/>
                            <field name="commission_rate"/>
                            <field name="commission_amount"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines" name="lines">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="sale_order_id"/>
                                    <field name="order_date"/>
                                    <field name="order_amount"/>
                                    <field name="delivery_date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" readonly="state == 'locked'"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <!-- Commission Record Search -->
    <record id="view_commission_record_search" model="ir.ui.view">
        <field name="name">hr.commission.record.search</field>
        <field name="model">hr.commission.record</field>
        <field name="arch" type="xml">
            <search string="Search Commission Records">
                <field name="employee_id"/>
                <field name="year"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="filter_confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Locked" name="filter_locked" domain="[('state', '=', 'locked')]"/>
                <separator/>
                <filter string="This Year" name="filter_this_year" domain="[('year', '=', context_today().year)]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="groupby_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Month" name="groupby_month" context="{'group_by': 'month'}"/>
                    <filter string="Year" name="groupby_year" context="{'group_by': 'year'}"/>
                    <filter string="Status" name="groupby_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Commission Record Action -->
    <record id="action_commission_record" model="ir.actions.act_window">
        <field name="name">Commission Records</field>
        <field name="res_model">hr.commission.record</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_commission_record_search"/>
        <field name="context">{'search_default_filter_this_year': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No commission records yet</p>
        </field>
    </record>
    
    <!-- Commission Line List -->
    <record id="view_commission_line_list" model="ir.ui.view">
        <field name="name">hr.commission.line.list</field>
        <field name="model">hr.commission.line</field>
        <field name="arch" type="xml">
            <list string="Commission Lines">
                <field name="employee_id"/>
                <field name="sale_order_id"/>
                <field name="order_date"/>
                <field name="order_amount"/>
                <field name="delivery_date"/>
                <field name="month"/>
                <field name="year"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    
    <!-- Commission Line Action -->
    <record id="action_commission_line" model="ir.actions.act_window">
        <field name="name">Commission Lines</field>
        <field name="res_model">hr.commission.line</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No commission lines yet</p>
        </field>
    </record>
    
</odoo>
