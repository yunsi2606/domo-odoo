<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW: hr.position.history -->
    <record id="view_hr_position_history_form" model="ir.ui.view">
        <field name="name">hr.position.history.form</field>
        <field name="model">hr.position.history</field>
        <field name="arch" type="xml">
            <form string="Position History">
                <sheet>

                    <div class="badge bg-success fs-6 float-end" invisible="not is_current">
                        ✓ Current Position
                    </div>

                    <group>
                        <group string="Employee Information">
                            <field name="employee_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Time">
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="is_current" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <group>
                        <group string="Position">
                            <field name="branch_id" readonly="1"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                            <field name="job_title"/>
                        </group>
                        <group string="Change">
                            <field name="change_type"/>
                            <field name="approved_by"/>
                        </group>
                    </group>

                    <group string="Reason / Notes">
                        <field name="reason" nolabel="1" placeholder="Reason / Notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW: hr.position.history -->
    <record id="view_hr_position_history_list" model="ir.ui.view">
        <field name="name">hr.position.history.list</field>
        <field name="model">hr.position.history</field>
        <field name="arch" type="xml">
            <list string="Position History"
                  decoration-success="is_current == True">
                <field name="employee_id" string="Employee"/>
                <field name="date_start" string="From Date"/>
                <field name="date_end" string="To Date"/>
                <field name="is_current" string="Current" widget="boolean"/>
                <field name="branch_id" string="Branch" optional="show"/>
                <field name="department_id" string="Department"/>
                <field name="job_id" string="Job"/>
                <field name="job_title" string="Job Title" optional="show"/>
                <field name="change_type" string="Change Type"/>
                <field name="reason" string="Reason" optional="hide"/>
                <field name="approved_by" string="Approved By" optional="show"/>
            </list>
        </field>
    </record>

    <!-- SEARCH VIEW: hr.position.history -->
    <record id="view_hr_position_history_search" model="ir.ui.view">
        <field name="name">hr.position.history.search</field>
        <field name="model">hr.position.history</field>
        <field name="arch" type="xml">
            <search string="Position History">
                <field name="employee_id" string="Nhân viên"/>
                <field name="department_id" string="Phòng ban"/>
                <field name="job_id" string="Vị trí"/>
                <separator/>
                <filter string="Current Position" name="filter_current"
                        domain="[('is_current', '=', True)]"/>
                <filter string="Promotion" name="filter_promotion"
                        domain="[('change_type', '=', 'promotion')]"/>
                <filter string="Transfer" name="filter_transfer"
                        domain="[('change_type', 'in', ['transfer', 'branch_transfer'])]"/>
                <separator/>
                <group expand="0" string="Group by">
                    <filter string="Employee" name="group_by_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="Department" name="group_by_dept"
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Branch" name="group_by_branch"
                            context="{'group_by': 'branch_id'}"/>
                    <filter string="Change Type" name="group_by_change_type"
                            context="{'group_by': 'change_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_hr_position_history" model="ir.actions.act_window">
        <field name="name">Employee Position History</field>
        <field name="res_model">hr.position.history</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_position_history_search"/>
        <field name="domain">[]</field>
    </record>

</odoo>
