<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════ -->
    <!-- FORM VIEW: hr.employee.document                     -->
    <!-- ════════════════════════════════════════════════════ -->
    <record id="view_hr_employee_document_form" model="ir.ui.view">
        <field name="name">hr.employee.document.form</field>
        <field name="model">hr.employee.document</field>
        <field name="arch" type="xml">
            <form string="Giấy tờ &amp; Tài liệu nhân viên">
                <header>
                    <button name="action_validate" type="object"
                            string="Xác minh hợp lệ" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_expire" type="object"
                            string="Đánh dấu hết hạn"
                            invisible="state not in ('draft', 'valid')"/>
                    <button name="action_lost" type="object"
                            string="Đánh dấu thất lạc"
                            invisible="state in ('lost',)"/>
                    <button name="action_reset_to_draft" type="object"
                            string="Đặt về chưa xác minh"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,valid,expired"/>
                </header>
                <sheet>
                    <!-- Alert khi sắp hết hạn -->
                    <div class="alert alert-warning" role="alert"
                         invisible="alert_level != 'warning'">
                        <i class="fa fa-exclamation-triangle me-1"/>
                        <strong>Cảnh báo:</strong> Tài liệu này sẽ hết hạn trong
                        <field name="days_to_expiry" nolabel="1" class="d-inline"/> ngày nữa.
                    </div>
                    <div class="alert alert-danger" role="alert"
                         invisible="alert_level != 'danger'">
                        <i class="fa fa-times-circle me-1"/>
                        <strong>Hết hạn:</strong> Tài liệu này đã hết hạn. Cần gia hạn hoặc cập nhật.
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Tên tài liệu..."/></h1>
                    </div>

                    <group>
                        <group string="Thông tin nhân viên">
                            <field name="employee_id" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Thông tin tài liệu">
                            <field name="document_type"/>
                            <field name="document_number"/>
                        </group>
                    </group>

                    <group>
                        <group string="Thời hạn">
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                            <field name="days_to_expiry"
                                   widget="integer"
                                   string="Ngày còn lại"
                                   invisible="not expiry_date"/>
                        </group>
                        <group string="Trạng thái cảnh báo">
                            <field name="alert_level" widget="badge"
                                   decoration-success="alert_level == 'ok'"
                                   decoration-warning="alert_level == 'warning'"
                                   decoration-danger="alert_level == 'danger'"/>
                        </group>
                    </group>

                    <group string="File đính kèm">
                        <field name="attachment_ids" nolabel="1" widget="many2many_binary"/>
                    </group>

                    <group string="Ghi chú">
                        <field name="notes" nolabel="1" placeholder="Ghi chú thêm..."/>
                    </group>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════ -->
    <!-- LIST VIEW: hr.employee.document                     -->
    <!-- ════════════════════════════════════════════════════ -->
    <record id="view_hr_employee_document_list" model="ir.ui.view">
        <field name="name">hr.employee.document.list</field>
        <field name="model">hr.employee.document</field>
        <field name="arch" type="xml">
            <list string="Giấy tờ nhân viên"
                  decoration-danger="alert_level == 'danger'"
                  decoration-warning="alert_level == 'warning'">
                <field name="employee_id" string="Nhân viên"/>
                <field name="name" string="Tên tài liệu"/>
                <field name="document_type" string="Loại"/>
                <field name="document_number" string="Số tài liệu"/>
                <field name="issue_date" string="Ngày cấp"/>
                <field name="expiry_date" string="Hết hạn"/>
                <field name="days_to_expiry" string="Còn (ngày)"
                       decoration-danger="days_to_expiry &lt; 0"
                       decoration-warning="days_to_expiry &gt;= 0 and days_to_expiry &lt;= 30"
                       optional="show"/>
                <field name="state" string="Trạng thái" widget="badge"
                       decoration-success="state == 'valid'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state in ('expired', 'lost')"/>
                <field name="alert_level" column_invisible="1"/>
                <field name="attachment_count" string="Files" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════ -->
    <!-- SEARCH VIEW: hr.employee.document                   -->
    <!-- ════════════════════════════════════════════════════ -->
    <record id="view_hr_employee_document_search" model="ir.ui.view">
        <field name="name">hr.employee.document.search</field>
        <field name="model">hr.employee.document</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm tài liệu">
                <field name="name" string="Tên tài liệu"/>
                <field name="employee_id" string="Nhân viên"/>
                <field name="document_number" string="Số tài liệu"/>
                <separator/>
                <filter string="Sắp hết hạn (30 ngày)" name="filter_expiring"
                        domain="[('alert_level', '=', 'warning')]"/>
                <filter string="Đã hết hạn" name="filter_expired"
                        domain="[('alert_level', '=', 'danger')]"/>
                <filter string="Đã xác minh" name="filter_valid"
                        domain="[('state', '=', 'valid')]"/>
                <separator/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Nhân viên" name="group_by_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="Loại tài liệu" name="group_by_type"
                            context="{'group_by': 'document_type'}"/>
                    <filter string="Trạng thái" name="group_by_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_hr_employee_document" model="ir.actions.act_window">
        <field name="name">Giấy tờ Nhân viên</field>
        <field name="res_model">hr.employee.document</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_employee_document_search"/>
        <field name="context">{}</field>
    </record>

</odoo>
