<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Cron: Kiểm tra hợp đồng sắp hết hạn mỗi ngày -->
    <record id="ir_cron_contract_expiry_check" model="ir.cron">
        <field name="name">HR Contract: Check for expiration date daily</field>
        <field name="model_id" ref="hr_contract.model_hr_contract"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_contract_expiry()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <!-- <field name="numbercall">-1</field> -->
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>

</odoo>
