<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Nhân viên: chỉ xem hợp đồng của chính mình -->
    <record id="rule_contract_employee_self" model="ir.rule">
        <field name="name">Contract: Employee</field>
        <field name="model_id" ref="hr_contract.model_hr_contract"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('hr_employee_custom.group_employee_self'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Quản lý chi nhánh: tạo/sửa hợp đồng trong chi nhánh mình -->
    <record id="rule_contract_branch_manager" model="ir.rule">
        <field name="name">Contract: Branch Manager</field>
        <field name="model_id" ref="hr_contract.model_hr_contract"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr_employee_custom.group_employee_branch_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Giám đốc: toàn quyền -->
    <record id="rule_contract_director" model="ir.rule">
        <field name="name">Contract: Director</field>
        <field name="model_id" ref="hr_contract.model_hr_contract"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr_employee_custom.group_employee_director'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Phụ cấp: Giám đốc toàn quyền -->
    <record id="rule_allowance_director" model="ir.rule">
        <field name="name">Contract Allowance: Director</field>
        <field name="model_id" ref="model_hr_contract_allowance"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr_employee_custom.group_employee_director'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Phụ cấp: Quản lý chi nhánh -->
    <record id="rule_allowance_branch_manager" model="ir.rule">
        <field name="name">Contract Allowance: Branch Manager</field>
        <field name="model_id" ref="model_hr_contract_allowance"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr_employee_custom.group_employee_branch_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Phụ cấp: Nhân viên (chỉ đọc phụ cấp của mình) -->
    <record id="rule_allowance_employee_self" model="ir.rule">
        <field name="name">Contract Allowance: Employee</field>
        <field name="model_id" ref="model_hr_contract_allowance"/>
        <field name="domain_force">[('contract_id.employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('hr_employee_custom.group_employee_self'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
