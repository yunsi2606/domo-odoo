<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_contract_reject_wizard_form" model="ir.ui.view">
        <field name="name">hr.contract.reject.wizard.form</field>
        <field name="model">hr.contract.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Contract">
                <div class="alert alert-warning" role="alert">
                    <i class="fa fa-exclamation-triangle me-1"/>
                    The contract will be <strong>rejected</strong> and the Branch Manager will be notified.
                </div>
                <group>
                    <field name="contract_id" readonly="1"/>
                    <field name="rejection_reason"
                           placeholder="Enter rejection reason..."
                           nolabel="1"
                           rows="4"/>
                </group>
                <footer>
                    <button name="action_confirm_reject" type="object"
                            string="Confirm Reject" class="btn-danger"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
