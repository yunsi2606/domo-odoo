<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         Attendance Correction Request — Views
    ═══════════════════════════════════════════════════════════════ -->

    <!-- ── 1. Form View ── -->
    <record id="hr_attendance_correction_view_form" model="ir.ui.view">
        <field name="name">hr.attendance.correction.form</field>
        <field name="model">hr.attendance.correction</field>
        <field name="arch" type="xml">
            <form string="Attendance Correction Request">
                <header>
                    <button name="action_submit"
                            string="Submit Request"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve"
                            string="Approve &amp; Apply"
                            type="object"
                            class="btn-primary"
                            groups="hr_attendance_custom.group_attendance_manager"
                            invisible="state != 'submitted'"
                            confirm="Bạn có chắc muốn phê duyệt và áp dụng sửa công này không? Dữ liệu chấm công sẽ được cập nhật ngay lập tức."/>
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            groups="hr_attendance_custom.group_attendance_manager"
                            invisible="state != 'submitted'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ('draft', 'submitted')"/>
                    <button name="action_reset_to_draft"
                            string="Reset to Draft"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ('submitted', 'rejected', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Summary Banner khi đã phê duyệt -->
                    <div class="alert alert-success mb-3"
                         invisible="state != 'approved'">
                        <i class="fa fa-check-circle"/> Yêu cầu đã được phê duyệt. Dữ liệu chấm công đã được cập nhật.
                        <field name="new_attendance_id" class="fw-bold" readonly="1"/>
                    </div>
                    <div class="alert alert-danger mb-3"
                         invisible="state != 'rejected'">
                        <i class="fa fa-times-circle"/> Yêu cầu bị từ chối:
                        <field name="rejection_reason" readonly="1" class="fw-bold"/>
                    </div>

                    <group>
                        <group string="Employee Information">
                            <field name="employee_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="department_id" readonly="1"/>
                            <field name="manager_id" readonly="1"/>
                        </group>
                        <group string="Correction Details">
                            <field name="date"
                                   readonly="state != 'draft'"/>
                            <field name="correction_type"
                                   readonly="state != 'draft'"
                                   widget="radio"/>
                        </group>
                    </group>

                    <group string="Current Attendance (System Record)" col="2"
                           invisible="attendance_id == False">
                        <field name="attendance_id" readonly="1"
                               options="{'no_create': True}"/>
                        <field name="actual_check_in" readonly="1" widget="datetime"/>
                        <field name="actual_check_out" readonly="1" widget="datetime"/>
                    </group>

                    <group string="Requested Times" col="2">
                        <field name="requested_check_in"
                               readonly="state != 'draft'"
                               widget="datetime"/>
                        <field name="requested_check_out"
                               readonly="state != 'draft'"
                               widget="datetime"/>
                    </group>

                    <group string="Reason &amp; Evidence">
                        <field name="reason" nolabel="1"
                               readonly="state != 'draft'"
                               placeholder="Vui lòng mô tả chi tiết lý do cần sửa công..."/>
                        <field name="evidence_attachment_ids"
                               widget="many2many_binary"
                               readonly="state != 'draft'"
                               string="Evidence Attachments"/>
                    </group>

                    <group string="Approval Info"
                           invisible="state not in ('approved', 'rejected')">
                        <field name="approved_by" readonly="1"/>
                        <field name="approval_date" readonly="1" widget="datetime"/>
                        <field name="rejection_reason"
                               invisible="state != 'rejected'"/>
                    </group>

                </sheet>

                <!-- Chatter -->
                <chatter/>

            </form>
        </field>
    </record>

    <!-- ── 2. List View ── -->
    <record id="hr_attendance_correction_view_list" model="ir.ui.view">
        <field name="name">hr.attendance.correction.list</field>
        <field name="model">hr.attendance.correction</field>
        <field name="arch" type="xml">
            <list string="Attendance Correction Requests"
                  decoration-success="state == 'approved'"
                  decoration-warning="state == 'submitted'"
                  decoration-danger="state == 'rejected'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="date"/>
                <field name="correction_type" widget="badge"/>
                <field name="requested_check_in" widget="datetime" string="Req. Check-in"/>
                <field name="requested_check_out" widget="datetime" string="Req. Check-out"/>
                <field name="reason" optional="hide"/>
                <field name="approved_by" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'submitted'"
                       decoration-danger="state == 'rejected'"
                       decoration-muted="state in ('cancelled','draft')"/>
            </list>
        </field>
    </record>

    <!-- ── 3. Kanban View ── -->
    <record id="hr_attendance_correction_view_kanban" model="ir.ui.view">
        <field name="name">hr.attendance.correction.kanban</field>
        <field name="model">hr.attendance.correction</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state"
                    group_create="false">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="date"/>
                <field name="correction_type"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_details">
                            <strong class="o_kanban_record_title">
                                <field name="name"/>
                            </strong>
                            <div>
                                <i class="fa fa-user"/> <field name="employee_id"/>
                            </div>
                            <div>
                                <i class="fa fa-calendar"/>
                                <field name="date"/>
                                — <field name="correction_type"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── 4. Search View ── -->
    <record id="hr_attendance_correction_view_search" model="ir.ui.view">
        <field name="name">hr.attendance.correction.search</field>
        <field name="model">hr.attendance.correction</field>
        <field name="arch" type="xml">
            <search string="Search Correction Requests">
                <field name="name" string="Reference"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="date"/>
                <separator/>
                <filter string="Pending Approval" name="filter_submitted"
                        domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="filter_approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="filter_rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <filter string="My Requests" name="filter_mine"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Forgot Check-in" name="filter_forgot_in"
                        domain="[('correction_type', '=', 'forgot_checkin')]"/>
                <filter string="Forgot Check-out" name="filter_forgot_out"
                        domain="[('correction_type', '=', 'forgot_checkout')]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="Department" name="group_dept"
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Type" name="group_type"
                            context="{'group_by': 'correction_type'}"/>
                    <filter string="Date" name="group_date"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── 5. Action Windows ── -->

    <!-- Action: All Correction Requests (Manager) -->
    <record id="action_attendance_correction_all" model="ir.actions.act_window">
        <field name="name">Correction Requests</field>
        <field name="res_model">hr.attendance.correction</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="hr_attendance_correction_view_search"/>
        <field name="context">{'search_default_filter_submitted': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có yêu cầu sửa công nào
            </p>
            <p>
                Nhân viên có thể gửi yêu cầu sửa công khi quên check-in/check-out
                hoặc ghi nhầm giờ chấm công.
            </p>
        </field>
    </record>

    <!-- Action: My Correction Requests (Employee) -->
    <record id="action_attendance_correction_my" model="ir.actions.act_window">
        <field name="name">My Correction Requests</field>
        <field name="res_model">hr.attendance.correction</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_attendance_correction_view_search"/>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_filter_mine': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Bạn chưa có yêu cầu sửa công nào
            </p>
            <p>Nhấn <b>New</b> để tạo yêu cầu sửa công mới.</p>
        </field>
    </record>

</odoo>
