<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ═══════════════════════════════════════
             Mail Templates: Correction Request
        ═══════════════════════════════════════ -->

        <!-- 1. Gửi yêu cầu sửa công → quản lý -->
        <record id="mail_template_correction_submitted" model="mail.template">
            <field name="name">Attendance Correction: Submitted</field>
            <field name="model_id" ref="model_hr_attendance_correction"/>
            <field name="subject">
                [Yêu cầu sửa công] {{ object.name }} - {{ object.employee_id.name }}
            </field>
            <field name="email_from">{{ (object.env.company.email or 'noreply@example.com') }}</field>
            <field name="email_to">
                {{ object.manager_id.work_email or object.manager_id.user_id.email or '' }}
            </field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; padding: 20px; max-width: 600px;">
    <h2 style="color: #e67e22; border-bottom: 2px solid #e67e22; padding-bottom: 8px;">
        📋 Yêu cầu sửa công mới
    </h2>
    <p>Xin chào <strong>{{ object.manager_id.name or 'Quản lý' }}</strong>,</p>
    <p>Nhân viên <strong>{{ object.employee_id.name }}</strong>
       ({{ object.department_id.name or 'N/A' }}) đã gửi yêu cầu sửa công.</p>
    <table style="width:100%; border-collapse:collapse; margin:12px 0;">
        <tr style="background:#f8f9fa;">
            <td style="padding:8px; border:1px solid #dee2e6; font-weight:bold; width:35%;">Mã yêu cầu</td>
            <td style="padding:8px; border:1px solid #dee2e6;">{{ object.name }}</td>
        </tr>
        <tr>
            <td style="padding:8px; border:1px solid #dee2e6; font-weight:bold;">Ngày cần sửa</td>
            <td style="padding:8px; border:1px solid #dee2e6;">{{ object.date }}</td>
        </tr>
        <tr style="background:#f8f9fa;">
            <td style="padding:8px; border:1px solid #dee2e6; font-weight:bold;">Loại lỗi</td>
            <td style="padding:8px; border:1px solid #dee2e6;">{{ object.correction_type }}</td>
        </tr>
        <tr>
            <td style="padding:8px; border:1px solid #dee2e6; font-weight:bold;">Giờ check-in đề nghị</td>
            <td style="padding:8px; border:1px solid #dee2e6;">
                {{ object.requested_check_in or 'Không thay đổi' }}
            </td>
        </tr>
        <tr style="background:#f8f9fa;">
            <td style="padding:8px; border:1px solid #dee2e6; font-weight:bold;">Giờ check-out đề nghị</td>
            <td style="padding:8px; border:1px solid #dee2e6;">
                {{ object.requested_check_out or 'Không thay đổi' }}
            </td>
        </tr>
        <tr>
            <td style="padding:8px; border:1px solid #dee2e6; font-weight:bold;">Lý do</td>
            <td style="padding:8px; border:1px solid #dee2e6;">{{ object.reason }}</td>
        </tr>
    </table>
    <p>Vui lòng truy cập hệ thống để xem xét và phê duyệt yêu cầu.</p>
    <p style="color:#7f8c8d; font-size:12px;">Email này được gửi tự động từ hệ thống DOMO.</p>
</div>
            ]]></field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- 2. Phê duyệt → nhân viên -->
        <record id="mail_template_correction_approved" model="mail.template">
            <field name="name">Attendance Correction: Approved</field>
            <field name="model_id" ref="model_hr_attendance_correction"/>
            <field name="subject">
                [Đã phê duyệt] Yêu cầu sửa công {{ object.name }}
            </field>
            <field name="email_from">{{ (object.env.company.email or 'noreply@example.com') }}</field>
            <field name="email_to">{{ object.employee_id.work_email or '' }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; padding: 20px; max-width: 600px;">
    <h2 style="color: #27ae60; border-bottom: 2px solid #27ae60; padding-bottom: 8px;">
        ✅ Yêu cầu sửa công đã được phê duyệt
    </h2>
    <p>Xin chào <strong>{{ object.employee_id.name }}</strong>,</p>
    <p>Yêu cầu sửa công <strong>{{ object.name }}</strong> của bạn cho ngày
       <strong>{{ object.date }}</strong> đã được <strong>{{ object.approved_by.name }}</strong>
       phê duyệt và dữ liệu đã được cập nhật vào hệ thống.</p>
    <p style="color:#7f8c8d; font-size:12px;">Email này được gửi tự động từ hệ thống DOMO.</p>
</div>
            ]]></field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- 3. Từ chối → nhân viên -->
        <record id="mail_template_correction_rejected" model="mail.template">
            <field name="name">Attendance Correction: Rejected</field>
            <field name="model_id" ref="model_hr_attendance_correction"/>
            <field name="subject">
                [Bị từ chối] Yêu cầu sửa công {{ object.name }}
            </field>
            <field name="email_from">{{ (object.env.company.email or 'noreply@example.com') }}</field>
            <field name="email_to">{{ object.employee_id.work_email or '' }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; padding: 20px; max-width: 600px;">
    <h2 style="color: #e74c3c; border-bottom: 2px solid #e74c3c; padding-bottom: 8px;">
        ❌ Yêu cầu sửa công bị từ chối
    </h2>
    <p>Xin chào <strong>{{ object.employee_id.name }}</strong>,</p>
    <p>Yêu cầu sửa công <strong>{{ object.name }}</strong> của bạn cho ngày
       <strong>{{ object.date }}</strong> đã bị từ chối.</p>
    <p><strong>Lý do từ chối:</strong> {{ object.rejection_reason or 'Không có lý do cụ thể.' }}</p>
    <p>Nếu bạn có thắc mắc, vui lòng liên hệ quản lý trực tiếp.</p>
    <p style="color:#7f8c8d; font-size:12px;">Email này được gửi tự động từ hệ thống DOMO.</p>
</div>
            ]]></field>
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>
