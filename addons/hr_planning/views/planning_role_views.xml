<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Planning Role List View -->
    <record id="planning_role_view_list" model="ir.ui.view">
        <field name="name">planning.role.list</field>
        <field name="model">planning.role</field>
        <field name="arch" type="xml">
            <list string="Planning Roles" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="slot_count"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>
    
    <!-- Planning Role Form View -->
    <record id="planning_role_view_form" model="ir.ui.view">
        <field name="name">planning.role.form</field>
        <field name="model">planning.role</field>
        <field name="arch" type="xml">
            <form string="Planning Role">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_slots" type="object" 
                                class="oe_stat_button" icon="fa-calendar">
                            <div class="o_stat_info">
                                <field name="slot_count" class="o_stat_value"/>
                                <span class="o_stat_text">Shifts</span>
                            </div>
                        </button>
                    </div>
                    
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" 
                            invisible="active"/>
                    
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Role Name"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Employees" name="employees">
                            <field name="resource_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Planning Role Kanban View -->
    <record id="planning_role_view_kanban" model="ir.ui.view">
        <field name="name">planning.role.kanban</field>
        <field name="model">planning.role</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard">
                <field name="name"/>
                <field name="color"/>
                <field name="slot_count"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-style="border-left: 4px solid #{kanban_color(record.color.raw_value)}">
                            <strong class="o_kanban_record_title">
                                <field name="name"/>
                            </strong>
                            <div class="text-muted mt-2">
                                <span><field name="slot_count"/> shifts</span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Planning Role Search View -->
    <record id="planning_role_view_search" model="ir.ui.view">
        <field name="name">planning.role.search</field>
        <field name="model">planning.role</field>
        <field name="arch" type="xml">
            <search string="Search Roles">
                <field name="name"/>
                <filter name="filter_active" string="Active" 
                        domain="[('active', '=', True)]"/>
                <filter name="filter_archived" string="Archived" 
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    
    <!-- Planning Role Action -->
    <record id="action_planning_role" model="ir.actions.act_window">
        <field name="name">Roles</field>
        <field name="res_model">planning.role</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="planning_role_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first role!
            </p>
            <p>
                Roles help organize shifts by job function (e.g., Cashier, Cook, Manager).
            </p>
        </field>
    </record>
    
</odoo>
