<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Planning Slot List View -->
    <record id="planning_slot_view_list" model="ir.ui.view">
        <field name="name">planning.slot.list</field>
        <field name="model">planning.slot</field>
        <field name="arch" type="xml">
            <list string="Planning Slots" 
                  decoration-danger="has_conflict" 
                  decoration-muted="state == 'cancel'"
                  decoration-success="state == 'done'"
                  multi_edit="1">
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="employee_id" widget="many2one_avatar_employee"/>
                <field name="role_id"/>
                <field name="allocated_hours" sum="Total Hours"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'published'"
                       decoration-muted="state == 'cancel'"/>
                <field name="has_conflict" column_invisible="1"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    
    <!-- Planning Slot Form View -->
    <record id="planning_slot_view_form" model="ir.ui.view">
        <field name="name">planning.slot.form</field>
        <field name="model">planning.slot</field>
        <field name="arch" type="xml">
            <form string="Planning Slot">
                <header>
                    <button name="action_publish" type="object" string="Publish" 
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_unpublish" type="object" string="Unpublish" 
                            invisible="state != 'published'"/>
                    <button name="action_done" type="object" string="Mark as Done" 
                            invisible="state not in ('draft', 'published')"/>
                    <button name="action_cancel" type="object" string="Cancel" 
                            invisible="state in ('cancel', 'done')"/>
                    <button name="action_draft" type="object" string="Reset to Draft" 
                            invisible="state not in ('cancel', 'done')"/>
                    <button name="action_send" type="object" string="Send" 
                            class="btn-secondary" invisible="state != 'published'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_conflicts" type="object" 
                                class="oe_stat_button" icon="fa-exclamation-triangle"
                                invisible="not has_conflict">
                            <div class="o_stat_info">
                                <field name="overlap_slot_count" class="o_stat_value text-danger"/>
                                <span class="o_stat_text text-danger">Conflicts</span>
                            </div>
                        </button>
                    </div>
                    
                    <widget name="web_ribbon" title="Conflict" bg_color="text-bg-danger" 
                            invisible="not has_conflict"/>
                    <widget name="web_ribbon" title="Time Off" bg_color="text-bg-warning" 
                            invisible="not is_leave"/>
                    
                    <group>
                        <group string="Assignment">
                            <field name="employee_id" widget="many2one_avatar_employee"/>
                            <field name="role_id"/>
                            <field name="template_id"/>
                        </group>
                        <group string="Schedule">
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                            <field name="allocated_hours"/>
                            <field name="allocated_percentage" widget="percentage"/>
                        </group>
                    </group>
                    
                    <group string="Recurrence" invisible="recurrency_id">
                        <group>
                            <field name="repeat"/>
                            <field name="repeat_interval" invisible="not repeat"/>
                            <field name="repeat_unit" invisible="not repeat"/>
                        </group>
                        <group invisible="not repeat">
                            <field name="repeat_type"/>
                            <field name="repeat_until" invisible="repeat_type != 'until'"/>
                            <field name="repeat_x_times" invisible="repeat_type != 'x_times'"/>
                        </group>
                    </group>
                    
                    <group string="Repeat On Days" 
                           invisible="not repeat or repeat_unit not in ('week', 'day')">
                        <div class="d-flex flex-wrap gap-3" colspan="2">
                            <span class="d-flex align-items-center gap-1">
                                <field name="repeat_monday" widget="boolean_toggle"/>
                                <label for="repeat_monday">Mon</label>
                            </span>
                            <span class="d-flex align-items-center gap-1">
                                <field name="repeat_tuesday" widget="boolean_toggle"/>
                                <label for="repeat_tuesday">Tue</label>
                            </span>
                            <span class="d-flex align-items-center gap-1">
                                <field name="repeat_wednesday" widget="boolean_toggle"/>
                                <label for="repeat_wednesday">Wed</label>
                            </span>
                            <span class="d-flex align-items-center gap-1">
                                <field name="repeat_thursday" widget="boolean_toggle"/>
                                <label for="repeat_thursday">Thu</label>
                            </span>
                            <span class="d-flex align-items-center gap-1">
                                <field name="repeat_friday" widget="boolean_toggle"/>
                                <label for="repeat_friday">Fri</label>
                            </span>
                            <span class="d-flex align-items-center gap-1">
                                <field name="repeat_saturday" widget="boolean_toggle"/>
                                <label for="repeat_saturday">Sat</label>
                            </span>
                            <span class="d-flex align-items-center gap-1">
                                <field name="repeat_sunday" widget="boolean_toggle"/>
                                <label for="repeat_sunday">Sun</label>
                            </span>
                        </div>
                    </group>
                    
                    <group>
                        <group>
                            <field name="name" placeholder="Add note..."/>
                            <field name="allow_self_unassign"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="recurrency_id" readonly="1" 
                                   invisible="not recurrency_id"/>
                        </group>
                    </group>
                    
                    <field name="has_conflict" invisible="1"/>
                    <field name="is_leave" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <!-- Planning Slot Calendar View -->
    <record id="planning_slot_view_calendar" model="ir.ui.view">
        <field name="name">planning.slot.calendar</field>
        <field name="model">planning.slot</field>
        <field name="arch" type="xml">
            <calendar string="Planning" 
                      date_start="start_datetime" 
                      date_stop="end_datetime" 
                      color="employee_id"
                      mode="week"
                      event_open_popup="true"
                      quick_create="0">
                <field name="employee_id" avatar_field="avatar_128"/>
                <field name="role_id"/>
                <field name="allocated_hours"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>
    
    <!-- Planning Slot Kanban View -->
    <record id="planning_slot_view_kanban" model="ir.ui.view">
        <field name="name">planning.slot.kanban</field>
        <field name="model">planning.slot</field>
        <field name="arch" type="xml">
            <kanban class="o_hr_employee_kanban" default_group_by="state" sample="1">
                <field name="employee_id"/>
                <field name="role_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="allocated_hours"/>
                <field name="state"/>
                <field name="color"/>
                <field name="has_conflict"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="#{record.has_conflict.raw_value ? 'border-danger' : ''}">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="employee_id" widget="many2one_avatar_employee"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="mb-2">
                                <span class="badge" t-att-style="'background-color:' + kanban_color(record.color.raw_value)">
                                    <field name="role_id"/>
                                </span>
                            </div>
                            <div class="text-muted">
                                <i class="fa fa-clock-o me-1"/>
                                <field name="start_datetime" widget="date"/>
                            </div>
                            <div class="mt-2">
                                <span class="badge bg-secondary">
                                    <field name="allocated_hours"/> hours
                                </span>
                                <span t-if="record.has_conflict.raw_value" class="badge bg-danger ms-1">
                                    <i class="fa fa-exclamation-triangle"/> Conflict
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Planning Slot Search View -->
    <record id="planning_slot_view_search" model="ir.ui.view">
        <field name="name">planning.slot.search</field>
        <field name="model">planning.slot</field>
        <field name="arch" type="xml">
            <search string="Search Planning">
                <field name="employee_id"/>
                <field name="role_id"/>
                <field name="department_id"/>
                <field name="name"/>
                <separator/>
                <filter name="filter_my_slots" string="My Shifts" 
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <filter name="filter_unassigned" string="Open Shifts" 
                        domain="[('employee_id', '=', False)]"/>
                <separator/>
                <filter name="filter_draft" string="Draft" 
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_published" string="Published" 
                        domain="[('state', '=', 'published')]"/>
                <filter name="filter_done" string="Done" 
                        domain="[('state', '=', 'done')]"/>
                <filter name="filter_cancelled" string="Cancelled" 
                        domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <filter name="filter_conflicts" string="Has Conflicts" 
                        domain="[('has_conflict', '=', True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee" 
                            context="{'group_by': 'employee_id'}"/>
                    <filter name="group_role" string="Role" 
                            context="{'group_by': 'role_id'}"/>
                    <filter name="group_department" string="Department" 
                            context="{'group_by': 'department_id'}"/>
                    <filter name="group_state" string="Status" 
                            context="{'group_by': 'state'}"/>
                    <filter name="group_start_date" string="Start Date" 
                            context="{'group_by': 'start_datetime:day'}"/>
                    <filter name="group_start_week" string="Week" 
                            context="{'group_by': 'start_datetime:week'}"/>
                    <filter name="group_start_month" string="Month" 
                            context="{'group_by': 'start_datetime:month'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Planning Slot Action -->
    <record id="action_planning_slot" model="ir.actions.act_window">
        <field name="name">Planning</field>
        <field name="res_model">planning.slot</field>
        <field name="view_mode">calendar,list,kanban,form</field>
        <field name="search_view_id" ref="planning_slot_view_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first shift!
            </p>
            <p>
                Plan and manage employee shifts with the Planning module.
            </p>
        </field>
    </record>
    
    <!-- Open Shifts Action -->
    <record id="action_planning_slot_open" model="ir.actions.act_window">
        <field name="name">Open Shifts</field>
        <field name="res_model">planning.slot</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="domain">[('employee_id', '=', False)]</field>
        <field name="context">{'default_allow_self_unassign': True}</field>
    </record>
    
    <!-- My Shifts Action (for employees) -->
    <record id="action_planning_slot_my" model="ir.actions.act_window">
        <field name="name">My Shifts</field>
        <field name="res_model">planning.slot</field>
        <field name="view_mode">calendar,list,form</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_filter_my_slots': 1}</field>
    </record>
    
    <!-- Conflicts Action -->
    <record id="action_planning_slot_conflicts" model="ir.actions.act_window">
        <field name="name">Scheduling Conflicts</field>
        <field name="res_model">planning.slot</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('has_conflict', '=', True)]</field>
    </record>
    
</odoo>
