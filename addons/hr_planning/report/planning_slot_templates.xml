<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Planning Schedule PDF Report Template -->
    <template id="report_planning_schedule">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="slot">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Shift Schedule</h2>
                        
                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Employee:</strong>
                                <span t-field="slot.employee_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Role:</strong>
                                <span t-field="slot.role_id.name"/>
                            </div>
                        </div>
                        
                        <div class="row mt-3">
                            <div class="col-6">
                                <strong>Start:</strong>
                                <span t-field="slot.start_datetime" t-options="{'widget': 'datetime'}"/>
                            </div>
                            <div class="col-6">
                                <strong>End:</strong>
                                <span t-field="slot.end_datetime" t-options="{'widget': 'datetime'}"/>
                            </div>
                        </div>
                        
                        <div class="row mt-3">
                            <div class="col-6">
                                <strong>Duration:</strong>
                                <span t-field="slot.allocated_hours"/> hours
                            </div>
                            <div class="col-6">
                                <strong>Status:</strong>
                                <span t-field="slot.state"/>
                            </div>
                        </div>
                        
                        <t t-if="slot.name">
                            <div class="row mt-3">
                                <div class="col-12">
                                    <strong>Notes:</strong>
                                    <p t-field="slot.name"/>
                                </div>
                            </div>
                        </t>
                        
                    </div>
                </t>
            </t>
        </t>
    </template>
    
    <!-- Employee Schedule PDF Report Template -->
    <template id="report_employee_schedule">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="employee">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Schedule for <t t-esc="employee.name"/></h2>
                        <p class="text-muted">
                            Department: <t t-esc="employee.department_id.name or 'N/A'"/>
                        </p>
                        
                        <t t-set="slots" t-value="env['planning.slot'].search([
                            ('employee_id', '=', employee.id),
                            ('state', '!=', 'cancel')
                        ], order='start_datetime')"/>
                        
                        <table class="table table-sm mt-4">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Time</th>
                                    <th>Role</th>
                                    <th>Hours</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="slots" t-as="slot">
                                    <tr>
                                        <td t-field="slot.start_datetime" t-options="{'widget': 'date'}"/>
                                        <td>
                                            <span t-field="slot.start_datetime" t-options="{'widget': 'datetime', 'format': 'HH:mm'}"/>
                                            -
                                            <span t-field="slot.end_datetime" t-options="{'widget': 'datetime', 'format': 'HH:mm'}"/>
                                        </td>
                                        <td t-field="slot.role_id.name"/>
                                        <td><t t-esc="'%.1f' % slot.allocated_hours"/></td>
                                        <td t-field="slot.state"/>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        
                        <t t-if="not slots">
                            <p class="text-muted">No scheduled shifts.</p>
                        </t>
                        
                        <div class="mt-4">
                            <strong>Total Hours:</strong>
                            <t t-esc="'%.1f' % sum(slots.mapped('allocated_hours'))"/>
                        </div>
                        
                    </div>
                </t>
            </t>
        </t>
    </template>
    
</odoo>
