<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for Recruitment Request -->
        <record id="seq_recruitment_request" model="ir.sequence">
            <field name="name">Recruitment Request</field>
            <field name="code">hr.recruitment.request</field>
            <field name="prefix">RR-%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Sequence for Offer Letter -->
        <record id="seq_offer_letter" model="ir.sequence">
            <field name="name">Offer Letter</field>
            <field name="code">hr.offer.letter</field>
            <field name="prefix">OL-%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>
