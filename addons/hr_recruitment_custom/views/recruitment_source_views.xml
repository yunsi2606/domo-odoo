<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================================== -->
    <!-- RECRUITMENT SOURCE CHANNEL VIEWS -->
    <!-- =========================================== -->

    <!-- Form View -->
    <record id="view_source_channel_form" model="ir.ui.view">
        <field name="name">hr.recruitment.source.channel.form</field>
        <field name="model">hr.recruitment.source.channel</field>
        <field name="arch" type="xml">
            <form string="Recruitment Source Channel">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="channel_type"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="url" widget="url"/>
                            <field name="active"/>
                            <field name="applicant_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_source_channel_list" model="ir.ui.view">
        <field name="name">hr.recruitment.source.channel.list</field>
        <field name="model">hr.recruitment.source.channel</field>
        <field name="arch" type="xml">
            <list string="Source Channels" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="channel_type"/>
                <field name="url" widget="url"/>
                <field name="applicant_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_source_channel" model="ir.actions.act_window">
        <field name="name">Source Channels</field>
        <field name="res_model">hr.recruitment.source.channel</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a recruitment source channel
            </p>
            <p>
                Manage where your applicants come from: websites, job boards, social media, etc.
            </p>
        </field>
    </record>

</odoo>
