<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="res_config_settings_view_form_telegram" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.telegram</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Telegram" name="telegram_notification">
                    <block title="Telegram Notifications" name="telegram_settings">
                        <setting string="Enable Telegram Notifications" 
                                 help="Send order notifications to Telegram when orders are confirmed">
                            <field name="telegram_enabled"/>
                        </setting>
                        <setting string="Bot Token" 
                                 help="Get from @BotFather on Telegram"
                                 invisible="not telegram_enabled">
                            <field name="telegram_bot_token" placeholder="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"/>
                        </setting>
                        <setting string="Chat ID" 
                                 help="Group ID (negative number) or Channel username"
                                 invisible="not telegram_enabled">
                            <field name="telegram_chat_id" placeholder="-123456789"/>
                        </setting>
                        <setting string="Odoo Base URL" 
                                 help="For order links. Leave empty to auto-detect."
                                 invisible="not telegram_enabled">
                            <field name="telegram_base_url" placeholder="https://yourodoo.com"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
    
</odoo>
